{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"mcp": {
		"backstage": {
			"enabled": false,
			"type": "remote",
			"url": "https://backstage.mcp.cfdata.org/mcp"
		},
		"cloudflare-docs": {
			"enabled": false,
			"type": "remote",
			"url": "https://docs.mcp.cloudflare.com/mcp"
		},
		"context7": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"elasticsearch": {
			"enabled": false,
			"type": "remote",
			"url": "https://elasticsearch.mcp.cfdata.org/mcp"
		},
		"gitlab": {
			"enabled": false,
			"type": "remote",
			"url": "https://gitlab.mcp.cfdata.org/mcp"
		},
		"grep_app": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.grep.app"
		},
		"jira": {
			"enabled": false,
			"type": "remote",
			"url": "https://jira.mcp.cfdata.org/mcp"
		},
		"opensrc": {
			"command": ["npx", "-y", "opensrc-mcp"],
			"enabled": true,
			"type": "local"
		},
		"overseer": {
			"command": ["npx", "-y", "@dmmulroy/overseer", "mcp"],
			"enabled": true,
			"type": "local"
		},
		"townlake": {
			"enabled": false,
			"type": "remote",
			"url": "https://mcp.townlake.cfdata.org/mcp"
		},
		"wiki": {
			"enabled": false,
			"type": "remote",
			"url": "https://wiki.mcp.cfdata.org/mcp"
		}
	},
	"permission": {
		"bash": {
			"*": "ask",
			"ast-grep *": "allow",
			"awk *": "allow",
			"basename *": "allow",
			"biome *": "allow",
			"bun *": "allow",
			"cargo *": "allow",
			"cat *": "allow",
			"cloc *": "allow",
			"cp *": "allow",
			"date *": "allow",
			"diff *": "allow",
			"dirname *": "allow",
			"du *": "allow",
			"echo *": "allow",
			"fd *": "allow",
			"file *": "allow",
			"find *": "allow",
			"fzf *": "allow",
			"gh *": "allow",
			"gh * approve*": "ask",
			"gh * close*": "ask",
			"gh * comment*": "ask",
			"gh * create*": "ask",
			"gh * delete*": "ask",
			"gh * edit*": "ask",
			"gh * merge*": "ask",
			"gh * reopen*": "ask",
			"gh * review*": "ask",
			"gh repo clone*": "allow",
			"git *": "allow",
			"git push*": "ask",
			"go *": "allow",
			"grep *": "allow",
			"gunzip *": "allow",
			"gzip *": "allow",
			"head *": "allow",
			"id": "allow",
			"jq *": "allow",
			"ls *": "allow",
			"make *": "allow",
			"mkdir *": "allow",
			"mv *": "allow",
			"npm *": "allow",
			"pnpm *": "allow",
			"prettier *": "allow",
			"printf *": "allow",
			"pwd": "allow",
			"readlink *": "allow",
			"realpath *": "allow",
			"rg *": "allow",
			"sed *": "allow",
			"sort *": "allow",
			"stat *": "allow",
			"stow *": "allow",
			"stylua *": "allow",
			"tail *": "allow",
			"tar *": "allow",
			"tee *": "allow",
			"touch *": "allow",
			"tr *": "allow",
			"true": "allow",
			"tsc *": "allow",
			"turbo *": "allow",
			"uname *": "allow",
			"uniq *": "allow",
			"unzip *": "allow",
			"vite *": "allow",
			"vitest *": "allow",
			"wc *": "allow",
			"which *": "allow",
			"whoami": "allow",
			"xargs *": "ask",
			"z *": "allow",
			"zip *": "allow",
			"zoxide *": "allow"
		},
		"edit": "allow",
		"external_directory": {
			"*": "ask",
			"~/.config/opencode/**": "allow",
			"~/.local/share/opencode/mcp-auth.json": "deny",
			"~/Dev/**": "allow",
			"~/dotfiles/**": "allow"
		},
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.envrc": "deny",
			".dev.vars": "ask",
			"secrets/*": "deny",
			"~/.local/share/opencode/mcp-auth.json": "deny"
		},
		"webfetch": "ask"
	},
	"provider": {
		"ollama": {
			"models": {
				"glm-5:cloud": {
					"_launch": true,
					"name": "glm-5:cloud"
				},
				"llama3.2": {
					"_launch": true,
					"name": "llama3.2"
				},
				"minimax-m2.5:cloud": {
					"_launch": true,
					"limit": {
						"context": 204800,
						"output": 128000
					},
					"name": "minimax-m2.5:cloud"
				}
			},
			"name": "Ollama (local)",
			"npm": "@ai-sdk/openai-compatible",
			"options": {
				"baseURL": "http://127.0.0.1:11434/v1"
			}
		}
	},
	"theme": "system"
}
