#!/bin/bash

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptÔÇŽ" "${args[@]}" 2>/dev/null
}

show_learn_menu() {
  case $(menu "Learn" "´äť  Keybindings\n´ŹÖ  Hyprland\nˇ░úç  Arch\nţÜ«  Neovim\nˇ▒ćâ  Bash") in
  *Keybindings*) menu-keybindings ;;
  *Hyprland*) launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "´Ç░  Screenshot\n´ÇŻ  Screenrecord\nˇ░âë  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "´Ç░  Snap with Editing\n´Ç░  Straight to Clipboard") in
  *Editing*) cmd-screenshot smart ;;
  *Clipboard*) cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

show_screenrecord_menu() {
  cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "´ÇŻ  With desktop audio\n´ÇŻ  With desktop + microphone audio\n´ÇŻ  With desktop + microphone audio + webcam") in
  *"With desktop audio") cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam") cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "´ü┐  Clipboard\nţę╗  File \n´äö  Folder") in
  *Clipboard*) cmd-share clipboard ;;
  *File*) terminal bash -c "cmd-share file" ;;
  *Folder*) terminal bash -c "cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_theme_menu() {
  launch-walker -m menus:themes --width 800 --minheight 400
}

show_main_menu() {
  go_to_menu "$(menu "Go" "ˇ░Ç╗  Apps\nˇ░žĹ  Learn\n")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchÔÇŽ" ;;
  *learn*) show_learn_menu ;;
  *share*) show_share_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi