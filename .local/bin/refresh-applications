#!/bin/bash

# # Copy and sync icon files
mkdir -p $XDG_DATA_HOME/icons/hicolor/48x48/apps/
cp $XDG_DATA_HOME/applications/icons/*.png $XDG_DATA_HOME/icons/hicolor/48x48/apps/
gtk-update-icon-cache $XDG_DATA_HOME/icons/hicolor &>/dev/null

# Copy .desktop declarations
mkdir -p $XDG_DATA_HOME/applications
cp /usr/share/applications/*.desktop $XDG_DATA_HOME/applications/

update-desktop-database $XDG_DATA_HOME/applications