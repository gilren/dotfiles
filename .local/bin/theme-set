#!/bin/bash

if [[ -z $1 && $1 != "CNCLD" ]]; then
  echo "Usage: theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$THEMES_DIR/current/theme"
NEXT_THEME_PATH="$THEMES_DIR/current/next-theme"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
THEME_PATH="$THEMES_AVAILABLE_DIR/$THEME_NAME"

# Check if the theme entered exists
if [[ ! -d "$THEME_PATH" ]]; then
  echo "Theme '$THEME_NAME' does not exist in $THEMES_AVAILABLE_DIR"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy static configs
cp -r "$THEME_PATH/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate dynamic configs
theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Setup bat theme symlink and rebuild cache
# TODO: Lets make the symlink on build one time
mkdir -p "$XDG_CONFIG_HOME/bat/themes"
ln -sf "$CURRENT_THEME_PATH/bat.tmTheme" "$XDG_CONFIG_HOME/bat/themes/current.tmTheme"
bat cache --build

# Store theme name for reference
echo "$THEME_NAME" > "$THEMES_DIR/current/theme.name"

# Change background with theme
theme-bg-next

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  restart-waybar
fi
restart-swayosd
restart-speedcrunch
restart-terminal
hyprctl reload
pkill -SIGUSR2 btop
pkill -SIGUSR2 opencode
makoctl reload

theme-set-gnome
theme-set-vscode
