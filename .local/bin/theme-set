#!/bin/bash

if [[ -z $1 && $1 != "CNCLD" ]]; then    
  echo "Usage: theme-set <theme-name>"
  exit 1
fi

THEMES_AVAILABLE_DIR="$XDG_CONFIG_HOME/themes/available"
CURRENT_THEME_DIR="$XDG_CONFIG_HOME/themes/current"
NEXT_THEME_DIR="$CURRENT_THEME_DIR/next-theme"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
THEME_PATH="$THEMES_AVAILABLE_DIR/$THEME_NAME"

# Check if the theme entered exists
if [[ ! -d "$THEME_PATH" ]]; then
  echo "Theme '$THEME_NAME' does not exist in $THEMES_AVAILABLE_DIR"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_DIR"
mkdir -p "$NEXT_THEME_DIR"

# Copy static configs
cp -r "$THEME_PATH/"* "$NEXT_THEME_DIR/" 2>/dev/null

# Generate dynamic configs
theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_DIR/theme"
mv "$NEXT_THEME_DIR" "$CURRENT_THEME_DIR/theme"

# Setup bat theme symlink and rebuild cache
# TODO: Lets make the symlink on build one time
mkdir -p "$XDG_CONFIG_HOME/bat/themes"
ln -sf "$CURRENT_THEME_DIR/theme/bat.tmTheme" "$XDG_CONFIG_HOME/bat/themes/current.tmTheme"
bat cache --build

# Setup fzf theme symlink
mkdir -p "$XDG_CONFIG_HOME/fzf"
ln -sf "$CURRENT_THEME_DIR/theme/fzf.sh" "$XDG_CONFIG_HOME/fzf/theme.sh"


# Store theme name for reference
echo "$THEME_NAME" > "$CURRENT_THEME_DIR/theme.name"

# Change background with theme
theme-bg-next

# Restart components to apply new theme
for app in waybar swayosd-server; do
  restart-app "$app" 2>/dev/null
done

if pgrep -x speedcrunch >/dev/null; then
    restart-app speedcrunch
fi

if pgrep -x kitty >/dev/null; then
  killall -SIGUSR1 kitty >/dev/null
fi

hyprctl reload
pkill -SIGUSR2 btop
pkill -SIGUSR2 opencode
# source ~/.fzf.zsh
makoctl reload

theme-set-gnome
theme-set-vscode
